.gradient-bg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:-2;background:radial-gradient(ellipse at 20% 30%,rgba(200,164,107,0.07),transparent 50%),radial-gradient(ellipse at 80% 70%,rgba(200,164,107,0.05),transparent 60%);animation:bgPulse 12s ease-in-out infinite}
